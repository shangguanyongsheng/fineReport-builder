<WebViewContent>
<Listener event="startload">
<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
<![CDATA[var sheet1Widgets = [
    "组织架构", "orgStructure",
    "架构版本", "structureVersion",
    "开始日期开始", "startStartDate",
    "开始日期结束", "endStartDate",
    "结束日期开始", "startEndDate",
    "结束日期结束", "endEndDate",
    "架构版本","structureVersion",
    "被授信人","orgId",
    "组织标签","orgTag",
    "是否包含下级","contain",
    "额度循环","isCirculate",
    "协议类型","creditProtocolType",
    "银行授信机构","financeBankCode",
    "其他授信机构","financeBankName",
    "融资品种","creditProductCode",
    "折算币种","convertCurrencyCode",
    "协议编号","contractCode",
    "授信类型","creditType",
    "批文授信","bizType",
    "Label统计列", "cols",
    "Reload", "Search"
]A;

// --- 【Sheet2 控件组】→ 仅在非 "明细" 的 Sheet 中显示（即 Sheet2 / Sheet3...）
var sheet2Widgets = [
    "开始日期开始2", "startStartDate2",
    "开始日期结束2", "endStartDate2",
    "结束日期开始2", "startEndDate2",
    "结束日期结束2", "endEndDate2",
    "被授信人2","orgId2",
    "组织标签2","orgTag2",
    "是否包含下级2","contain2",
    "额度循环2","isCirculate2",
    "协议类型2","creditProtocolType2",
    "银行授信机构2","financeBankCode2",
    "其他授信机构2","financeBankName2",
    "融资品种2","creditProductCode2",
    "折算币种2","convertCurrencyCode2",
    "授信类型2","financeTypeCode2",
    "批文授信2","bizType2",
    "Reload2", "Search2"
]A; 


if (contentPane.$contentPane.data('TabPane')) {
    contentPane.$contentPane.data('TabPane').on('tabchange', function(event, newIndex) {
        // ✅ 安全获取当前 Sheet 名（兼容 FR 10.x / 11.x，规避 ?. 语法报错）
        var tabPane = contentPane.$contentPane.data('TabPane');
        var tabBtns = tabPane && tabPane.tabBtns;
        var tabBtn = tabBtns && newIndex >= 0 && newIndex < tabBtns.length ? tabBtns[newIndex]A : null;
        var currentSheetName = tabBtn && tabBtn.options && tabBtn.options.name || "";
        console.log("🔄 当前 Sheet 名:", currentSheetName);

        // ✅ 核心判断：Sheet1 = "明细"；其余均为 Sheet2（可按需扩展为多 Sheet）
        var isSheet1 = (currentSheetName === "明细");

        // ▶️ Step 1：控制显隐
        sheet1Widgets.forEach(function(name) {
            var w = contentPane.parameterEl.getWidgetByName(name);
            if (w) w.setVisible(isSheet1); // 只在 Sheet1 显示
        });

        sheet2Widgets.forEach(function(name) {
            var w = contentPane.parameterEl.getWidgetByName(name);
            if (w) {
                w.setVisible(!isSheet1); // 在非 Sheet1 的所有 Sheet 显示（即 Sheet2+）
            }
        });

    contentPane.parameterEl.getWidgetByName("triggerRequest1").setValue(isSheet1);
    contentPane.parameterEl.getWidgetByName("triggerRequest2").setValue(!isSheet1);
        console.log("✅ Sheet 切换完成：当前为 Sheet1（明细）=" + isSheet1);
    
//        _g().parameterCommit();

  

        
    });
    
}
 ]]></Content>
</JavaScript>
</Listener>
<Listener event="afterload">
<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
