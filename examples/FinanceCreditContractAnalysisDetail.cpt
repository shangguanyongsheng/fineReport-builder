<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
<![CDATA[var sheet1Widgets = [
  "orgStructure",
"structureVersion",
"startStartDate",
"endStartDate",
"startEndDate",
"endEndDate",
"structureVersion",
"orgId",
"orgTag",
"contain",
"isCirculate",
"creditProtocolType",
"financeBankCode",
"financeBankName",
"creditProductCode",
"convertCurrencyCode",
"contractCode",
"cols",
"creditType",
"bizType"
]A;

  var form = this.options.form;
 sheet1Widgets.forEach(function(name) {
            console.log("sheet1Widgets 重置开始");
            form.getWidgetByName(name).reset();
        });
       


this.options.form.getWidgetByName("cols").setValue('授信类型,协议编号,被授信人,授信机构,机构网点,协议类型,额度循环,币种,授信总额,已用授信总额,可用授信总额,敞口额度,可用敞口额度,敞口受限额度,受限说明,备注,协议开始日,协议截止日,增信方式,担保单位,抵质押物名称,授信产品,产品币种,产品授信额度,产品已用授信,产品可用授信,产品敞口额度,产品敞口已用,产品敞口可用,产品敞口受限,产品低风险额度,产品低风险已用,产品低风险可用');]]></Content>
</JavaScript>
