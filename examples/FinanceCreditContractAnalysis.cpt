<Widget class="com.fr.form.ui.container.WAbsoluteLayout$BoundsWidget">
<InnerWidget class="com.fr.form.ui.DateEditor">
<Listener event="stopedit" name="编辑结束1">
<JavaScript class="com.fr.js.JavaScriptImpl">
<Parameters/>
<Content>
<![CDATA[// ✅ 校验：开始日期开始 <= 开始日期结束
function validateDateRange() {
    // 1. 获取两个控件
    var startWidget = contentPane.parameterEl.getWidgetByName("startEndDate2");
    var endWidget   = contentPane.parameterEl.getWidgetByName("endEndDate2");

    if (!startWidget || !endWidget) {
        return true;
    }

    // 2. 获取值（字符串）
    var startDateStr = startWidget.getValue(); // 如 "2025-03-01"
    var endDateStr   = endWidget.getValue();

    // 4. 转为 Date 对象（注意：帆软日期格式为 YYYY-MM-DD）
    var startDate = new Date(startDateStr);
    var endDate   = new Date(endDateStr);

    // 6. 核心逻辑：开始日期 > 结束日期？ → 不合法！
    if (startDate > endDate) {
        alert("开始日期不能晚于结束日期！\n请调整：开始日期开始 ≤ 开始日期结束");
        startWidget.setValue("");
        return false;
    }


    // ✅ 校验通过
    return true;
}

// 执行校验并返回结果（关键！必须 return false 阻止提交）
return validateDateRange();]]></Content>
</JavaScript>
</Listener>
