        "type": "DBTableData",
        "database": "\ncfs-report",
        "sql": "\nSELECT so.`version`,concat(so.id,'') as id FROM u_sys_organization_structure so \nWHERE so.tenant_id = '${fine_username9}' AND so.is_deleted = 0\n${if(len(structureVersion)=0,\"AND 1=2\",if(structureVersion=1,\"AND so.structure_type =( '\"+ structureVersion +\"')  and so.effective_date<=DATE_FORMAT(NOW(),'%Y-%m-%d') and so.expiry_date>=DATE_FORMAT(NOW(),'%Y-%m-%d')\",\"AND so.structure_type =( '\"+ structureVersion +\"')\"))}",
        "parameters": [
          {
            "name": "fine_username9",
            "default": "\n"
          },
          {
            "name": "structureVersion",
            "default": "\n"
          }
        ]
      },
