      {
        "name": "orgStructure",
        "type": "DBTableData",
        "database": "\ncfs-report",
        "sql": "\nSELECT so.`version`,concat(so.id,'') as id FROM u_sys_organization_structure so \nWHERE so.tenant_id = '${fine_username9}' AND so.is_deleted = 0\n${if(len(structureVersion)=0,\"AND 1=2\",if(structureVersion=1,\"AND so.structure_type =( '\"+ structureVersion +\"')  and so.effective_date<=DATE_FORMAT(NOW(),'%Y-%m-%d') and so.expiry_date>=DATE_FORMAT(NOW(),'%Y-%m-%d')\",\"AND so.structure_type =( '\"+ structureVersion +\"')\"))}",
        "parameters": [
          {
            "name": "fine_username9",
            "default": "\n"
          },
          {
            "name": "structureVersion",
            "default": "\n"
          }
        ]
      },
      {
        "name": "structureVersion",
        "type": "DBTableData",
        "database": "\ncfs-report",
        "sql": "\nSELECT\n\t\tsd1.dict_key,\n\t\tsd1.dict_value \n\tFROM\n\t\tsys_dict sd1 \n\tWHERE\n\t sd1.`code` = 'org_structure' \n\tAND sd1.is_deleted = 0 \tAND sd1.`status` = 1;",
        "parameters": []
      },
      {
        "name": "Tree1",
        "type": "RecursionTableData"
      },
      {
        "name": "currency",
        "type": "DBTableData",
        "database": "\ncfs-report",
        "sql": "\nselect concat(id,'') as id,code,dict_key,dict_value from sys_dict where code = 'currency' and is_deleted = 0",
        "parameters": []
      },
      {
        "name": "organization",
        "type": "DBTableData",
        "database": "\ncfs-report",
